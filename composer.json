{
    "name": "codeldev/laravel-schedule-log",
    "description": "A simple Laravel package that automatically logs every scheduled command execution to your database. It listens to Laravel's built-in scheduler\nevents to record information without wrapping or modifying the scheduler itself. Ships with configurable table names, swappable Eloquent models, and a built-in prune command to manage retention.",
    "keywords": [
        "codeldev",
        "laravel",
        "laravel-schedule-log"
    ],
    "homepage": "https://github.com/codeldev/laravel-schedule-log",
    "license": "MIT",
    "authors": [
        {
            "name": "CodelDev",
            "email": "support@codel.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.93",
        "illuminate/contracts": "*"
    },
    "require-dev": {
        "larastan/larastan": "^3.9.3",
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9.3",
        "nunomaduro/pao": "0.x-dev",
        "orchestra/testbench": "^11.1.0",
        "peckphp/peck": "^0.3.0",
        "pestphp/pest": "^4.4.6",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "rector/rector": "^2.4.1",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ray": "^1.43.7"
    },
    "autoload": {
        "psr-4": {
            "CodelDev\\LaravelScheduleLog\\": "src/",
            "CodelDev\\LaravelScheduleLog\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodelDev\\LaravelScheduleLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "lint" : "pint",
        "refactor" : "rector",
        "test:unit" : "pest --parallel --coverage --exactly=100",
        "test:types" : "phpstan",
        "test:lint" : "pint --test",
        "test:typos" : "peck",
        "test:refactor" : "rector --dry-run",
        "test" : [
            "@test:unit",
            "@test:lint",
            "@test:types",
            "@test:refactor",
            "@test:typos"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodelDev\\LaravelScheduleLog\\LaravelScheduleLogServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
